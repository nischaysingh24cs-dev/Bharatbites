"use client";

import Image from "next/image";
import Link from "next/link";
import { AnimatePresence, motion } from "framer-motion";
import { Droplets, Minus, Plus, RotateCcw, Sparkles } from "lucide-react";
import { useState } from "react";
import { foods } from "@/data/foods";
import { getFoodAdvice } from "@/lib/advisor";
import { Button } from "@/components/ui/button";
import { SectionHeading } from "@/components/ui/section-heading";
import { cn } from "@/lib/utils";

const paniPuri = foods[0];
export function SmartCounter() {
  const [count, setCount] = useState(8);
  const advice = getFoodAdvice(paniPuri, count);
  const calories = Math.round((paniPuri.calories / 6) * count);
  return (
    <section className="overflow-hidden bg-ink-950 py-20 text-white sm:py-28">
      <div className="container-page grid items-center gap-12 lg:grid-cols-[.8fr_1.2fr]">
        <div>
          <SectionHeading
            inverse
            eyebrow="Smart food counter"
            title="Eat with awareness, not anxiety."
            description="Log portions in seconds. Our advisor responds with kind, contextual suggestions—never shame or rigid rules."
          />
          <div className="mt-7 flex flex-wrap gap-2 text-xs text-white/60">
            <span className="rounded-full border border-white/10 px-3 py-1.5">
              ✓ Voice logging
            </span>
            <span className="rounded-full border border-white/10 px-3 py-1.5">
              ✓ Indian portions
            </span>
            <span className="rounded-full border border-white/10 px-3 py-1.5">
              ✓ Positive nudges
            </span>
          </div>
          <Link href="/tracker">
            <Button className="mt-8">Try the full tracker</Button>
          </Link>
        </div>
        <div className="relative rounded-[30px] border border-white/10 bg-white/[0.06] p-4 shadow-2xl backdrop-blur sm:p-6">
          <div className="grid gap-4 sm:grid-cols-[1fr_1.15fr]">
            <div className="relative min-h-[300px] overflow-hidden rounded-[22px]">
              <Image
                src={paniPuri.image}
                alt="Pani puri"
                fill
                sizes="400px"
                className="object-cover"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent" />
              <div className="absolute bottom-5 left-5">
                <span className="rounded-full bg-leaf-500 px-2.5 py-1 text-[9px] font-bold uppercase">
                  Street favourite
                </span>
                <h3 className="mt-2 text-2xl font-extrabold">Pani Puri</h3>
                <p className="text-xs text-white/60">
                  Maharashtra · 6 piece serving
                </p>
              </div>
            </div>
            <div className="rounded-[22px] bg-white p-5 text-ink-950 dark:bg-white/10 dark:text-white">
              <p className="text-[10px] font-bold uppercase tracking-[.18em] text-slate-400">
                Today&apos;s count
              </p>
              <div className="mt-3 flex items-center justify-between">
                <button
                  className="grid size-11 place-items-center rounded-full border border-black/10 transition hover:border-saffron-500 dark:border-white/10"
                  onClick={() => setCount(Math.max(0, count - 1))}
                  aria-label="Remove one"
                >
                  <Minus className="size-4" />
                </button>
                <AnimatePresence mode="popLayout">
                  <motion.span
                    key={count}
                    initial={{ opacity: 0, y: -8 }}
                    animate={{ opacity: 1, y: 0 }}
                    exit={{ opacity: 0, y: 8 }}
                    className="text-5xl font-extrabold tracking-tight"
                  >
                    {count}
                  </motion.span>
                </AnimatePresence>
                <button
                  className="grid size-11 place-items-center rounded-full bg-saffron-500 text-white shadow-glow transition hover:scale-105"
                  onClick={() => setCount(count + 1)}
                  aria-label="Add one"
                >
                  <Plus className="size-4" />
                </button>
              </div>
              <div className="mt-5 grid grid-cols-2 gap-2">
                <div className="rounded-xl bg-saffron-50 p-3 dark:bg-saffron-500/10">
                  <b className="block text-lg text-saffron-600 dark:text-saffron-400">
                    {calories}
                  </b>
                  <small className="text-[10px] text-slate-500">
                    calories est.
                  </small>
                </div>
                <div className="rounded-xl bg-blue-50 p-3 dark:bg-blue-500/10">
                  <b className="flex items-center gap-1 text-lg text-blue-600 dark:text-blue-400">
                    <Droplets className="size-4" />
                    {advice.waterMl}
                  </b>
                  <small className="text-[10px] text-slate-500">ml water</small>
                </div>
              </div>
              <div
                className={cn(
                  "mt-3 rounded-2xl border p-3",
                  advice.tone === "great"
                    ? "border-leaf-500/20 bg-leaf-500/10"
                    : advice.tone === "mindful"
                      ? "border-amber-500/20 bg-amber-500/10"
                      : "border-saffron-500/20 bg-saffron-500/10"
                )}
              >
                <div className="flex items-center gap-1.5 text-xs font-bold">
                  <Sparkles className="size-3.5 text-saffron-500" />
                  {advice.title}
                </div>
                <p className="mt-1 text-[10px] leading-4 text-slate-600 dark:text-slate-300">
                  {advice.message}
                </p>
              </div>
              <button
                onClick={() => setCount(0)}
                className="mt-3 flex items-center gap-1 text-[10px] font-semibold text-slate-400 hover:text-saffron-500"
              >
                <RotateCcw className="size-3" />
                Reset today
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  );
}
