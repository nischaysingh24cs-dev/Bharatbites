"use client";

import Image from "next/image";
import Link from "next/link";
import { motion } from "framer-motion";
import { ArrowRight, MapPin } from "lucide-react";
import { useMemo, useState } from "react";
import { foods, states } from "@/data/foods";
import { SectionHeading } from "@/components/ui/section-heading";

const points = [
  ["Jammu & Kashmir", 42, 9],
  ["Punjab", 34, 20],
  ["Himachal Pradesh", 46, 18],
  ["Delhi", 40, 27],
  ["Rajasthan", 28, 35],
  ["Uttar Pradesh", 49, 34],
  ["Bihar", 64, 39],
  ["Sikkim", 76, 36],
  ["Assam", 85, 37],
  ["Gujarat", 22, 49],
  ["Madhya Pradesh", 42, 48],
  ["Jharkhand", 64, 48],
  ["West Bengal", 70, 51],
  ["Odisha", 62, 58],
  ["Maharashtra", 34, 59],
  ["Chhattisgarh", 51, 57],
  ["Telangana", 43, 67],
  ["Goa", 29, 70],
  ["Karnataka", 35, 76],
  ["Andhra Pradesh", 49, 75],
  ["Kerala", 36, 90],
  ["Tamil Nadu", 45, 88],
  ["Nagaland", 91, 41],
  ["Manipur", 90, 47],
  ["Mizoram", 87, 54],
  ["Meghalaya", 80, 42],
  ["Tripura", 81, 51],
  ["Arunachal Pradesh", 89, 30]
] as const;

export function StateExplorer() {
  const [selected, setSelected] = useState("Karnataka");
  const dish = useMemo(
    () => foods.find((food) => food.state === selected) ?? foods[0],
    [selected]
  );
  return (
    <section className="india-pattern bg-[#faf7f1] py-20 dark:bg-white/[0.025] sm:py-28">
      <div className="container-page">
        <SectionHeading
          align="center"
          eyebrow="36 regions, endless flavours"
          title="Taste your way across India"
          description="Tap a state to discover its signature dishes, culinary story and nutrition—made easy to understand."
        />
        <div className="mt-12 grid overflow-hidden rounded-[32px] border border-black/[0.07] bg-white shadow-soft dark:border-white/10 dark:bg-white/[0.055] lg:grid-cols-[1.1fr_.9fr]">
          <div className="relative min-h-[520px] overflow-hidden bg-gradient-to-br from-leaf-50 to-saffron-50 p-5 dark:from-leaf-500/10 dark:to-saffron-500/10 sm:p-8">
            <div className="flex items-center justify-between">
              <div>
                <p className="text-xs font-bold uppercase tracking-wider text-leaf-600">
                  Interactive food map
                </p>
                <p className="mt-1 text-sm text-slate-500">
                  Choose any glowing point
                </p>
              </div>
              <select
                value={selected}
                onChange={(e) => setSelected(e.target.value)}
                className="max-w-[180px] rounded-full border border-black/10 bg-white px-3 py-2 text-xs font-semibold text-ink-950 dark:border-white/10 dark:bg-ink-900 dark:text-white"
                aria-label="Select Indian state"
              >
                {states.map((state) => (
                  <option key={state}>{state}</option>
                ))}
              </select>
            </div>
            <div
              className="relative mx-auto mt-6 aspect-[.9/1] max-h-[420px] max-w-[390px]"
              role="img"
              aria-label="Interactive stylised map of India"
            >
              <svg
                viewBox="0 0 100 100"
                className="absolute inset-0 h-full w-full drop-shadow-xl"
                aria-hidden="true"
              >
                <path
                  d="M37 4L50 7l4 8 12 3 7 9 17-2 5 8-11 8-3 17-12 7-7 13-12 3-3 16-7 9-6-19-9-10-2-13-13-6 5-13-4-12 9-8 3-12 10-4z"
                  fill="currentColor"
                  className="text-white dark:text-white/10"
                  stroke="rgba(0,168,107,.28)"
                  strokeWidth="1"
                />
                <path
                  d="M35 87Q44 91 40 98"
                  fill="none"
                  stroke="#ff6b00"
                  strokeWidth="1"
                  opacity=".5"
                />
              </svg>
              {points.map(([state, x, y]) => (
                <button
                  key={state}
                  onClick={() => setSelected(state)}
                  className="group absolute -translate-x-1/2 -translate-y-1/2"
                  style={{ left: `${x}%`, top: `${y}%` }}
                  aria-label={`Explore ${state}`}
                >
                  <span
                    className={`block rounded-full border-2 border-white shadow-md transition-all ${selected === state ? "size-4 bg-saffron-500 ring-4 ring-saffron-500/20" : "size-2.5 bg-leaf-500 group-hover:scale-150"}`}
                  />
                  <span
                    className={`pointer-events-none absolute bottom-full left-1/2 mb-1 -translate-x-1/2 whitespace-nowrap rounded bg-ink-950 px-2 py-1 text-[8px] font-semibold text-white transition ${selected === state ? "opacity-100" : "opacity-0 group-hover:opacity-100"}`}
                  >
                    {state}
                  </span>
                </button>
              ))}
            </div>
          </div>
          <motion.div
            key={dish.id}
            initial={{ opacity: 0, x: 12 }}
            animate={{ opacity: 1, x: 0 }}
            className="flex flex-col p-5 sm:p-8"
          >
            <div className="relative h-56 overflow-hidden rounded-[22px]">
              <Image
                src={dish.image}
                alt={dish.name}
                fill
                sizes="500px"
                className="object-cover"
              />
              <div className="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent" />
              <div className="absolute bottom-4 left-4 flex items-center gap-1 rounded-full bg-white/15 px-3 py-1 text-xs font-semibold text-white backdrop-blur">
                <MapPin className="size-3" />
                {dish.state}
              </div>
            </div>
            <div className="mt-6">
              <p className="text-xs font-bold uppercase tracking-wider text-saffron-500">
                Featured from {selected}
              </p>
              <h3 className="mt-2 text-3xl font-extrabold tracking-tight text-ink-950 dark:text-white">
                {dish.name}
              </h3>
              <p className="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-300">
                {dish.history}
              </p>
            </div>
            <div className="mt-5 grid grid-cols-4 gap-2">
              {[
                [dish.calories, "kcal"],
                [`${dish.protein}g`, "protein"],
                [`${dish.fiber}g`, "fiber"],
                [`${dish.healthRating}%`, "score"]
              ].map(([v, l]) => (
                <div
                  key={l}
                  className="rounded-xl bg-slate-50 p-2.5 text-center dark:bg-white/[0.06]"
                >
                  <b className="block text-sm text-ink-950 dark:text-white">
                    {v}
                  </b>
                  <span className="text-[9px] uppercase text-slate-400">
                    {l}
                  </span>
                </div>
              ))}
            </div>
            <Link
              href={`/explore?state=${encodeURIComponent(selected)}`}
              className="mt-auto flex items-center gap-1 pt-6 text-sm font-bold text-saffron-600 hover:gap-2"
            >
              Explore food from {selected} <ArrowRight className="size-4" />
            </Link>
          </motion.div>
        </div>
      </div>
    </section>
  );
}
